{
  "base_config": {
    "service_class": {
      "classes": [
        {
          "class_id": 0,
          "description": "Replay traffic ChatGPT Conversation log",
          "arrival_mode": "trace_replay",
          "model": "ChatGPT",
          "log_type": "Conversation log",
          "trace_file": "../traces/BurstGPT_without_fails_1.csv",
          "traffic_scale": 1
        },
        {
          "class_id": 1,
          "description": "Modeled traffic GPT-4 API log",
          "arrival_mode": "modeled_gamma",
          "model": "GPT-4",
          "log_type": "API log",
          "gamma_params_file": "gamma_params.example.csv",
          "zipf_params_file": "zipf_params.example.txt",
          "scale_gamma": 1.0,
          "scale_beta": 1.0,
          "response_linear": {
            "slope": 0.7,
            "intercept": 32.0
          }
        }
      ]
    },
    "worker_class": {
      "classes": [
        {
          "class_id": 0,
          "description": "Contention-aware workers",
          "count": 4,
          "service_model": "contention_lognormal",
          "queue_timeout_seconds": null,
          "params": {
            "a": 0.03,
            "b": 0.002,
            "c": 0.12,
            "d": 0.015,
            "sigma": 0.2,
            "min_s": 0.001
          }
        },
        {
          "class_id": 1,
          "description": "Linear workers",
          "count": 4,
          "service_model": "linear_lognormal",
          "params": {
            "a": 0.04,
            "b": 0.003,
            "sigma": 0.1,
            "min_s": 0.001
          }
        }
      ]
    },
    "controller": {
      "latency_tracker": {
        "init_estimate": 0.5,
        "ewma_gamma": 0.1,
        "redirect_policy": {
          "name": "fixed_rate",
          "params": {
            "rate": 0.05
          }
        }
      }
    }
  },
  "scenarios": [
    {
      "name": "baseline",
      "override": {}
    },
    {
      "name": "split_topology",
      "override": {
        "topology": {
          "service_class_worker_ids": {
            "0": [0, 1, 2, 3],
            "1": [4, 5, 6, 7]
          },
          "service_class_worker_weights": {
            "0": {
              "0": 1.0,
              "1": 1.0,
              "2": 2.0,
              "3": 2.0
            },
            "1": {
              "4": 2.0,
              "5": 2.0,
              "6": 1.0,
              "7": 1.0
            }
          }
        }
      }
    },
    {
      "name": "lp_wrr_control",
      "override": {
        "controller": {
          "latency_tracker": {
            "init_estimate": 0.5,
            "ewma_gamma": 0.1,
            "redirect_policy": {
              "name": "fixed_rate",
              "params": {
                "rate": 0.05
              }
            }
          },
          "lp-wrr": {
            "update_interval_seconds": 60.0,
            "min_weight": 0.2,
            "max_weight": 5.0,
            "lp_balance_tolerance": 0.25,
            "lp_ewma_gamma": 0.1
          }
        }
      }
    }
  ],
  "sweeps": {
    "baseline": {
      "service_class.classes[0].traffic_scale": [1, 2, 3],
      "service_class.classes[1].scale_gamma": [0.8, 1.0, 1.2],
      "service_class.classes[1].scale_beta": [0.8, 1.0, 1.2]
    },
    "split_topology": {
      "topology.service_class_worker_ids.0": [[0, 1, 2], [0, 1, 3], [0, 2, 3]],
      "topology.service_class_worker_ids.1": [[4, 5, 6], [5, 6, 7]]
    },
    "lp_wrr_control": {
      "controller.latency_tracker.ewma_gamma": {
        "min": 0.05,
        "max": 0.20,
        "step": 0.05
      },
      "controller.lp-wrr.update_interval_seconds": [30, 60, 90],
      "controller.lp-wrr.lp_ewma_gamma": [0.05, 0.1, 0.2]
    }
  }
}
